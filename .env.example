# Supabase — browser auth (Project Settings → API)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="your-anon-public-key"

# Prisma / PostgreSQL — Session pooler (IPv4). Copy from Supabase → Database → Connect.
# Example shape (region varies per project):
DATABASE_URL="postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

PORT=3001

# Netlify — add the same SUPABASE_* values in Site settings → Environment variables
# (build writes public/config.json and enables /api/* via serverless functions)
